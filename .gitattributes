# Fins de ligne normalisees a la case-out (LF), detection auto du texte.
* text=auto eol=lf

# Assets binaires : pas de conversion de fin de ligne, pas de diff texte.
*.png  binary
*.gif  binary
*.jpg  binary
*.pdf  binary
