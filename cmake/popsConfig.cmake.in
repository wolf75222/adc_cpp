# Config find_package(pops) -- genere par configure_package_config_file (CMakeLists racine).
# La cible pops::pops est header-only ; ses dependances OPTIONNELLES (figees a l'INSTALL : un
# paquet installe avec Kokkos/MPI exige le meme backend chez le consommateur, c'est l'ABI).
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(@POPS_HAS_KOKKOS@)
  find_dependency(Kokkos REQUIRED)
endif()
if(@POPS_HAS_MPI@)
  find_dependency(MPI REQUIRED)
endif()
# NB: pas de bloc OpenMP ici. Le backend OpenMP autonome a ete retire (ADC-263) et
# @POPS_USE_OPENMP@ n'est plus defini (il s'expansait en `if()` toujours faux -- mort). Pour un
# install Kokkos-OpenMP, la dependance OpenMP est tiree transitivement par KokkosConfig via le
# find_dependency(Kokkos) ci-dessus (ADC-387).

include("${CMAKE_CURRENT_LIST_DIR}/popsTargets.cmake")
check_required_components(pops)
