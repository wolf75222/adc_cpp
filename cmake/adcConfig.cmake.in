# Config find_package(adc) -- genere par configure_package_config_file (CMakeLists racine).
# La cible adc::adc est header-only ; ses dependances OPTIONNELLES (figees a l'INSTALL : un
# paquet installe avec Kokkos/MPI exige le meme backend chez le consommateur, c'est l'ABI).
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(@ADC_HAS_KOKKOS@)
  find_dependency(Kokkos REQUIRED)
endif()
if(@ADC_HAS_MPI@)
  find_dependency(MPI REQUIRED)
endif()
if(@ADC_USE_OPENMP@)
  find_dependency(OpenMP REQUIRED COMPONENTS CXX)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/adcTargets.cmake")
check_required_components(adc)
