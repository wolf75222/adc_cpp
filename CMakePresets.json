{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "conda",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "notEquals",
        "lhs": "$env{CONDA_PREFIX}",
        "rhs": ""
      }
    },

    {
      "name": "python",
      "inherits": "conda",
      "displayName": "Module Python _adc (SERIE, CPU 1 thread)",
      "description": "Build du seul module _adc, sans tests. Exige l'env conda ACTIF (conda activate adc) : l'interpreteur est pinne sur celui de l'env.",
      "binaryDir": "${sourceDir}/build-py",
      "cacheVariables": {
        "ADC_BUILD_PYTHON": "ON",
        "ADC_BUILD_TESTS": "OFF",
        "Python_ROOT_DIR": "$env{CONDA_PREFIX}"
      }
    },
    {
      "name": "python-parallel",
      "inherits": "python",
      "displayName": "Module Python _adc (PARALLELE, dispatch Kokkos)",
      "description": "Comme 'python' mais via Kokkos ($CONDA_PREFIX). ATTENTION : le kokkos conda-forge est souvent Serial-only -> verifier 'Kokkos found ... = (OPENMP...)' au configure ; sinon `bash scripts/kokkos_openmp_conda.sh` installe un Kokkos OpenMP dans l'env (~2 min). Threads au runtime : adc.set_threads().",
      "binaryDir": "${sourceDir}/build-py-kokkos",
      "cacheVariables": {
        "ADC_USE_KOKKOS": "ON",
        "Kokkos_ROOT": "$env{CONDA_PREFIX}"
      }
    },

    {
      "name": "serial",
      "inherits": "base",
      "displayName": "Coeur + tests C++ (SERIE)",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "ADC_BUILD_TESTS": "ON" }
    },
    {
      "name": "parallel",
      "inherits": "conda",
      "displayName": "Coeur + tests C++ (PARALLELE, dispatch Kokkos)",
      "description": "Kokkos pris dans l'env conda actif ; cf. preset python-parallel pour la note kokkos conda Serial-only.",
      "binaryDir": "${sourceDir}/build-kokkos",
      "cacheVariables": {
        "ADC_BUILD_TESTS": "ON",
        "ADC_USE_KOKKOS": "ON",
        "Kokkos_ROOT": "$env{CONDA_PREFIX}"
      }
    },
    {
      "name": "mpi",
      "inherits": "conda",
      "displayName": "Coeur + tests C++ (MPI distribue)",
      "description": "OpenMPI pris dans l'env conda actif (conda activate adc).",
      "binaryDir": "${sourceDir}/build-mpi",
      "cacheVariables": {
        "ADC_BUILD_TESTS": "ON",
        "ADC_USE_MPI": "ON",
        "CMAKE_PREFIX_PATH": "$env{CONDA_PREFIX}"
      }
    },

    {
      "name": "ci-serial",
      "inherits": "base",
      "displayName": "CI : Release + tests (runner ubuntu, deps apt)",
      "description": "Source de verite des flags du job 'Release' de ci.yml. ccache auto-detecte (ADC_USE_CCACHE).",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "ADC_BUILD_TESTS": "ON" }
    },
    {
      "name": "ci-python",
      "inherits": "base",
      "displayName": "CI : module Python _adc (serie)",
      "description": "Job 'Build + test Python module' de ci.yml. Tests C++ coupes : ce job ne lance que les tests python/tests/*.py.",
      "binaryDir": "${sourceDir}/build-py",
      "cacheVariables": {
        "ADC_BUILD_PYTHON": "ON",
        "ADC_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "ci-mpi",
      "inherits": "base",
      "displayName": "CI : Release + tests, backend MPI",
      "binaryDir": "${sourceDir}/build-mpi",
      "cacheVariables": {
        "ADC_BUILD_TESTS": "ON",
        "ADC_USE_MPI": "ON"
      }
    },
    {
      "name": "ci-kokkos",
      "inherits": "base",
      "displayName": "CI : Release + tests, backend Kokkos",
      "description": "Kokkos pointe par la variable d'environnement KOKKOS_PREFIX (posee par le job : install mise en cache). Sert aux jobs Kokkos Serial ET OpenMP (seule l'install Kokkos differe).",
      "binaryDir": "${sourceDir}/build-kokkos",
      "condition": { "type": "notEquals", "lhs": "$env{KOKKOS_PREFIX}", "rhs": "" },
      "cacheVariables": {
        "ADC_BUILD_TESTS": "ON",
        "ADC_USE_KOKKOS": "ON",
        "Kokkos_ROOT": "$env{KOKKOS_PREFIX}"
      }
    },
    {
      "name": "ci-kokkos-python",
      "inherits": "ci-kokkos",
      "displayName": "CI : module Python _adc, backend Kokkos",
      "description": "Garde-fou ABI std du DSL production sous Kokkos (loader c++20), cf. ci.yml job kokkos-openmp.",
      "binaryDir": "${sourceDir}/build-kokkos-py",
      "cacheVariables": {
        "ADC_BUILD_PYTHON": "ON",
        "ADC_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "ci-bench",
      "inherits": "base",
      "displayName": "CI : compile-test du harnais bench/ (jamais execute)",
      "description": "bench/ n'est jamais configure par defaut : sans ce job, une signature qui change dans le coeur peut le casser sans detection (pourriture silencieuse).",
      "binaryDir": "${sourceDir}/build-bench",
      "cacheVariables": {
        "ADC_BUILD_BENCH": "ON",
        "ADC_BUILD_TESTS": "OFF"
      }
    }
  ],

  "buildPresets": [
    { "name": "python",          "configurePreset": "python",          "targets": ["_adc"] },
    { "name": "python-parallel", "configurePreset": "python-parallel", "targets": ["_adc"] },
    { "name": "serial",          "configurePreset": "serial" },
    { "name": "parallel",        "configurePreset": "parallel" },
    { "name": "mpi",             "configurePreset": "mpi" },

    { "name": "ci-serial",        "configurePreset": "ci-serial",        "jobs": 2 },
    { "name": "ci-python",        "configurePreset": "ci-python",        "jobs": 2, "targets": ["_adc"] },
    { "name": "ci-mpi",           "configurePreset": "ci-mpi",           "jobs": 2 },
    { "name": "ci-kokkos",        "configurePreset": "ci-kokkos",        "jobs": 2 },
    { "name": "ci-kokkos-python", "configurePreset": "ci-kokkos-python", "jobs": 2, "targets": ["_adc"] },
    { "name": "ci-bench",         "configurePreset": "ci-bench",         "jobs": 2 }
  ],

  "testPresets": [
    { "name": "serial",   "configurePreset": "serial",   "output": { "outputOnFailure": true } },
    { "name": "parallel", "configurePreset": "parallel", "output": { "outputOnFailure": true } },
    { "name": "mpi",      "configurePreset": "mpi",      "output": { "outputOnFailure": true } },

    { "name": "ci-serial", "configurePreset": "ci-serial", "output": { "outputOnFailure": true },
      "execution": { "jobs": 2 } },
    { "name": "ci-mpi",    "configurePreset": "ci-mpi",    "output": { "outputOnFailure": true },
      "execution": { "jobs": 2 } },
    { "name": "ci-kokkos", "configurePreset": "ci-kokkos", "output": { "outputOnFailure": true },
      "execution": { "jobs": 2 } }
  ]
}
